# ─── Spring Profile ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev


# ─── PostgreSQL (Supabase or Local Connection) ──────────────────
# You can paste a single connection URI (e.g. postgresql://user:pass@host:port/dbname?sslmode=require or jdbc:postgresql://...)
POSTGRES_URL=jdbc:postgresql://<host>:5432/<database>?sslmode=require


# ─── MongoDB (Atlas or Local Connection) ─────────────────────
# For Atlas, use: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<app_name>
MONGODB_URI=mongodb+srv://<mongodb_user>:<mongodb_password>@<cluster>.mongodb.net/<database>?appName=<app_name>


# ─── Redis (Redis Cloud, Upstash, or Local Connection) ───────
# For Upstash or Redis Cloud, paste the single URL string (e.g. rediss://default:password@host:6379)
REDIS_URL=redis://localhost:6379


# ─── JWT ────────────────────────────────────────────────────
# Must be at least 64 characters. Generate with: openssl rand -base64 64
JWT_SECRET=<jwt_secret>
JWT_ACCESS_EXPIRATION_MS=<jwt_access_expiration_ms>
JWT_REFRESH_EXPIRATION_MS=<jwt_refresh_expiration_ms>

# ─── Resend Email API Config ────────────────────────────────
RESEND_API_KEY=<resend_api_key>
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── Application ────────────────────────────────────────────
FRONTEND_URL=<frontend_url>
EMAIL_VERIFICATION_REQUIRED=<email_verification_required>
FILE_CLEANUP_INTERVAL_MS=<file_cleanup_interval_ms>
FILE_CLEANUP_THRESHOLD_MINUTES=<file_cleanup_threshold_minutes>

# ─── Admin Initialization ─────────────────────────────────────
# System administrator account automatically seeded on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<your_secure_admin_password>
