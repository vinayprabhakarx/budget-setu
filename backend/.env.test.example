# ─── Spring Profile ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=test

# ─── PostgreSQL (Local Docker Connection for Tests) ─────────────
POSTGRES_URL=jdbc:postgresql://localhost:5432/budgetsetu
POSTGRES_USER=budgetsetu_user
POSTGRES_PASSWORD=your_strong_password_here

# ─── MongoDB (Local Docker Connection for Tests) ────────────────
MONGODB_URI=mongodb://localhost:27017/budgetsetu_docs

# ─── Redis (Local Docker Connection for Tests) ──────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (Dummy Test Secret) ────────────────────────────────────
JWT_SECRET=ThisIsADefaultTestSecretKeyThatMustBeAtLeast64CharactersLongForHS512Algorithm!!
JWT_EXPIRATION_MS=86400000
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
FILE_CLEANUP_THRESHOLD_MINUTES=10

# ─── Resend Email API Config (Safe Dummy Test Credentials) ──────
RESEND_API_KEY="re_test_dummy_key_do_not_leak"
RESEND_FROM_EMAIL="BudgetSetu Test <no-reply@test.budgetsetu.app>"

# ─── Application ────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_REQUIRED=false

# ─── Admin Initialization (Safe Test Admin) ─────────────────────
ADMIN_EMAIL=testadmin@budgetsetu.app
ADMIN_PASSWORD=test_admin_password_123
