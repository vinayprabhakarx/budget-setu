# ─── PostgreSQL (Supabase Connection Example) ─────────────────
# For Supabase, use the direct JDBC connection (usually host is db.[project-id].supabase.co on port 5432)
POSTGRES_URL=jdbc:postgresql://db.vhwruwpqubpnzdrojegl.supabase.co:5432/postgres?sslmode=require
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_supabase_db_password
POSTGRES_DB=postgres


# ─── MongoDB (Atlas or Local Connection) ─────────────────────
# For Atlas, use: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=budgetsetu_docs


# ─── Redis (Redis Cloud or Local Connection) ────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=


# ─── JWT ────────────────────────────────────────────────────
# Must be at least 64 characters. Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_very_long_random_secret_key_minimum_64_chars_use_openssl_rand
JWT_EXPIRATION_MS=86400000

# ─── Mailgun SMTP / API Config ──────────────────────────────
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@your-domain.com
MAIL_PASSWORD=""
MAIL_FROM_EMAIL=no-reply@budgetsetu.app

MAILGUN_API_KEY=""
MAILGUN_SENDING_KEY=""
MAILGUN_DOMAIN=""

# ─── Spring Profile ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Application ────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_REQUIRED=true
FILE_CLEANUP_INTERVAL_MS=300000
FILE_CLEANUP_THRESHOLD_MINUTES=10

# ─── Admin Initialization ─────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
