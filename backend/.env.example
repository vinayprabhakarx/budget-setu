# ─── PostgreSQL (Supabase Connection Example) ─────────────────
# For Supabase, use the direct JDBC connection (usually host is db.[project-id].supabase.co on port 5432)
POSTGRES_URL=jdbc:postgresql://<supabase-host>:5432/<database>?sslmode=require
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=your_supabase_db_password
POSTGRES_DB=<db_name>


# ─── MongoDB (Atlas or Local Connection) ─────────────────────
# For Atlas, use: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<mongodb_user>:<mongodb_password>@<cluster>.mongodb.net/<database>?appName=<app_name>
MONGODB_DATABASE=<mongodb_database>


# ─── Redis (Redis Cloud or Local Connection) ────────────────
REDIS_URL=<redis_url>
REDIS_HOST=<redis_host>
REDIS_PORT=<redis_port>
REDIS_USERNAME=<redis_username>
REDIS_PASSWORD=<redis_password>


# ─── JWT ────────────────────────────────────────────────────
# Must be at least 64 characters. Generate with: openssl rand -base64 64
JWT_SECRET=<jwt_secret>
JWT_ACCESS_EXPIRATION_MS=<jwt_access_expiration_ms>
JWT_REFRESH_EXPIRATION_MS=<jwt_refresh_expiration_ms>

# ─── Mailgun SMTP / API Config ──────────────────────────────
MAIL_HOST=<mail_host>
MAIL_PORT=<mail_port>
MAIL_USERNAME=<mail_username>
MAIL_PASSWORD=<mail_password>
MAIL_FROM_EMAIL=<mail_from_email>

MAILGUN_API_KEY=<mailgun_api_key>
MAILGUN_SENDING_KEY=<mailgun_sending_key>
MAILGUN_DOMAIN=<mailgun_domain>

# ─── Spring Profile ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Application ────────────────────────────────────────────
FRONTEND_URL=<frontend_url>
EMAIL_VERIFICATION_REQUIRED=<email_verification_required>
FILE_CLEANUP_INTERVAL_MS=<file_cleanup_interval_ms>
FILE_CLEANUP_THRESHOLD_MINUTES=<file_cleanup_threshold_minutes>

# ─── Admin Initialization ─────────────────────────────────────
ADMIN_EMAIL=<admin_email>
ADMIN_PASSWORD=<admin_password>
